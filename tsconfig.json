{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@eight2five/shared": ["packages/shared/src/index"],
      "@eight2five/shared/*": ["packages/shared/src/*"]
    }
  },
  "include": [
    "apps/**/*",
    "packages/**/*",
    "modules/**/*",
    "eslint.config.js",
    "babel.config.js"
  ],
  "exclude": ["node_modules"]
}
